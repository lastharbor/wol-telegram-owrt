#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034
START=99
USE_PROCD=1

# Long-poll бот (Python). Не запускайте второй экземпляр с тем же токеном.
PROG=/usr/bin/woltelegram

validate() {
	config_load woltelegram
	config_get token main bot_token
	config_get chats main allowed_chat_ids
	if [ -z "$token" ] || [ -z "$chats" ]; then
		logger -t woltelegram "Refuse to start: set bot_token and allowed_chat_ids in UCI / LuCI"
		return 1
	fi
	return 0
}

reload_service() {
	stop
	start
}

start_service() {
	config_load woltelegram
	config_get enabled main enabled
	[ "$enabled" = "1" ] || return 0
	validate || return 1

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param file /etc/config/woltelegram
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "woltelegram"
}
