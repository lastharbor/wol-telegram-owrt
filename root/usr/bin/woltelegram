#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Единая точка входа (procd / ручной запуск):
  woltelegram              — бот (long-poll)
  woltelegram sync-chatids [файл_с_токеном]  — дописать chat_id из getUpdates в UCI
"""
from __future__ import annotations

import sys
from pathlib import Path

_SHARE = Path("/usr/share/woltelegram")
if _SHARE.is_dir() and str(_SHARE) not in sys.path:
    sys.path.insert(0, str(_SHARE))


def _run_bot() -> None:
    from woltg_main import main as bot_main

    bot_main()


def _run_sync(argv: list[str]) -> int:
    from woltg_sync import sync_main

    return sync_main(argv)


if __name__ == "__main__":
    av = sys.argv[1:]
    if av and av[0] == "sync-chatids":
        raise SystemExit(_run_sync(av[1:]))
    _run_bot()
